# =============================================================================
# Application
# =============================================================================
APP_ENV=development
DEBUG=true

# =============================================================================
# Database
# =============================================================================
# Must use postgresql+asyncpg:// scheme
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/haircut_booking

# =============================================================================
# Telegram
# =============================================================================
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_MASTER_CHAT_ID=123456789
# Secret token for webhook verification (optional, skip validation if empty)
TELEGRAM_WEBHOOK_SECRET=
# Public HTTPS URL Telegram will POST updates to (optional, skip registration if empty)
TELEGRAM_WEBHOOK_URL=

# =============================================================================
# Anthropic / Claude
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# =============================================================================
# Google Calendar MCP
# =============================================================================
# The ID of the dedicated appointments calendar (e.g. xxx@group.calendar.google.com)
GOOGLE_CALENDAR_ID=
# Absolute path to gcp-oauth.keys.json downloaded from Google Cloud Console
GOOGLE_OAUTH_CREDENTIALS_PATH=

# Master contact info (shown to clients who ask how to reach the master)
MASTER_CONTACT_PHONE=

# MCP account name for calendar write operations (create/update/delete).
# Run: npx @cocal/google-calendar-mcp list-accounts
GOOGLE_CALENDAR_ACCOUNT=normal

# =============================================================================
# Booking Rules
# =============================================================================
BOOKING_HORIZON_DAYS=30
MIN_NOTICE_HOURS=2
WORKING_HOURS_START=9
WORKING_HOURS_END=19
APPOINTMENT_DURATION_MINUTES=60
# Working days as JSON array: 0=Mon … 6=Sun
WORKING_DAYS=[0,1,2,3,4,5]
APP_TIMEZONE=Asia/Almaty
