# Application
APP_ENV=development
DEBUG=true

# Database — use postgresql+asyncpg:// for the async driver
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/haircut_booking

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_MASTER_CHAT_ID=123456789
TELEGRAM_WEBHOOK_SECRET=generate_a_random_secret_here

# Anthropic Claude (populated when Claude integration is added)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Calendar (populated when calendar integration is added)
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Booking rules
BOOKING_HORIZON_DAYS=30
MIN_NOTICE_HOURS=2
WORKING_HOURS_START=9
WORKING_HOURS_END=19
